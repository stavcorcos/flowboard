# Copy this to .env.local

# Postgres connection strings
POSTGRES_URL="postgres://USER:PASSWORD@HOST:5432/verceldb?sslmode=require"
POSTGRES_URL_NON_POOLING="postgres://USER:PASSWORD@HOST:5432/verceldb?sslmode=require"

# NextAuth — generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"
